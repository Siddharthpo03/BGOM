generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ACCOUNTANT
  STAFF
}

enum VoucherType {
  SALES
  PURCHASE
}

model User {
  id        String        @id @default(cuid())
  name      String
  email     String        @unique
  password  String
  companies UserCompany[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Company {
  id            String        @id @default(cuid())
  name          String
  address       String?
  gstNumber     String?
  financialYear String?
  state         String?
  contactNumber String?
  users         UserCompany[]
  customers     Customer[]
  suppliers     Supplier[]
  stockGroups   StockGroup[]
  stockItems    StockItem[]
  vouchers      Voucher[]     // 🔑 Added back-relation for Vouchers
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model UserCompany {
  id        String  @id @default(cuid())
  userId    String
  companyId String
  role      Role
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model Customer {
  id                 String   @id @default(cuid())
  companyId          String
  name               String
  mobile             String?
  email              String?
  address            String?
  outstandingBalance Decimal  @default(0)
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Supplier {
  id                 String   @id @default(cuid())
  companyId          String
  name               String
  mobile             String?
  email              String?
  address            String?
  outstandingBalance Decimal  @default(0)
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model StockGroup {
  id        String      @id @default(cuid())
  companyId String
  name      String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items     StockItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model StockItem {
  id            String        @id @default(cuid())
  companyId     String
  stockGroupId  String?
  name          String
  sku           String        @unique
  purchasePrice Decimal
  sellingPrice  Decimal
  quantity      Int           @default(0)
  gstPercentage Float         @default(0)
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockGroup    StockGroup?   @relation(fields: [stockGroupId], references: [id])
  voucherItems  VoucherItem[] // 🔑 Added back-relation for Voucher Items
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Voucher {
  id          String        @id @default(cuid())
  companyId   String
  type        VoucherType
  partyId     String
  date        DateTime      @default(now())
  totalAmount Decimal       @default(0)
  totalTax    Decimal       @default(0)
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items       VoucherItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model VoucherItem {
  id          String    @id @default(cuid())
  voucherId   String
  stockItemId String
  quantity    Int
  price       Decimal
  taxAmount   Decimal   @default(0)
  voucher     Voucher   @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
}